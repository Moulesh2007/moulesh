# Google Maps API Key for Fleet Tracking
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Client ID for Login
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# Backend API (host Express separately on Render/Railway, then paste URL here)
VITE_API_URL=https://your-api.example.com/api

# Socket.io server URL (optional; fleet tracking uses mock data if unset)
VITE_SOCKET_URL=https://your-api.example.com
